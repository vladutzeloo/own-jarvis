# Secret shared between server and all clients (phone, jarvis.exe)
JARVIS_SECRET=change-me-to-a-strong-passphrase

# Ollama base URL (default: local Ollama on same machine)
OLLAMA_URL=http://localhost:11434

# Qwen Coder model name (run: ollama list)
OLLAMA_MODEL=qwen2.5-coder:7b

# Port the Node server listens on
PORT=3000

# GitHub repo URL for the vault (used for git sync)
VAULT_REPO=https://github.com/vladutzeloo/own-jarvis.git

# Local path where the vault is cloned on the VPS
VAULT_PATH=/var/jarvis/vault

# How often to git pull the vault (milliseconds, default 10 min)
VAULT_SYNC_INTERVAL=600000
