# Obsidian local state (machine-specific, shouldn't be committed)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/*/data.json

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# Trash
.trash/

# Local secrets — never commit. Template lives at .env.example
.env
.env.local
.env.*.local

# Node / build artifacts (apps/*)
node_modules/
**/node_modules/
**/dist/
**/.vite/
*.log

# Python bytecode (skills sometimes ship .py scripts)
__pycache__/
*.pyc
